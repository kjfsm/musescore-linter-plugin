{
	"name": "musescore-linter-plugin",
	"version": "2.1.6",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"build": "tsx scripts/build.ts",
		"package": "tsx scripts/package.ts",
		"pipeline": "turbo run typecheck test build package",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit",
		"turbo:typecheck": "turbo run typecheck",
		"dev": "vitest",
		"knip": "knip",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"changeset": "changeset",
		"version": "changeset version",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm lint"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@musescore-linter/checkers": "workspace:*",
		"@musescore-linter/core": "workspace:*",
		"@types/node": "^25.9.1",
		"@vitest/coverage-v8": "^4.1.7",
		"esbuild": "^0.28.0",
		"fflate": "^0.8.3",
		"knip": "^6.14.2",
		"simple-git-hooks": "^2.13.1",
		"tsx": "^4.22.3",
		"turbo": "^2.9.14",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"simple-git-hooks"
		]
	}
}
