{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": [
		"biome.json",
		"tsconfig.json",
		"vitest.config.ts",
		"pnpm-lock.yaml"
	],
	"tasks": {
		"typecheck": {
			"description": "TypeScript の型チェックを実行する。依存パッケージの typecheck が先に完了している必要がある。",
			"dependsOn": ["^typecheck"]
		},
		"test": {
			"description": "vitest でユニットテストを実行する。typecheck が通過していることが前提。",
			"dependsOn": ["typecheck"],
			"outputs": []
		},
		"//#build": {
			"description": "esbuild でプラグインをバンドルし dist/ へ出力する。core・checkers パッケージのテスト通過後に実行される。",
			"dependsOn": [
				"@musescore-linter/musescore-api#typecheck",
				"@musescore-linter/core#test",
				"@musescore-linter/checkers#test"
			],
			"inputs": [
				"src/**",
				"scripts/build.ts",
				"packages/core/src/**",
				"packages/checkers/src/**"
			],
			"outputs": ["dist/**"]
		},
		"//#package": {
			"description": "dist/ の成果物を配布用 ZIP にパッケージングする。",
			"dependsOn": ["//#build"],
			"inputs": ["dist/**", "README.md", "package.json", "scripts/package.ts"],
			"outputs": ["musescore-linter-plugin-*.zip"]
		}
	}
}
