{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		"skipLibCheck": true
	},
	"references": [
		{ "path": "packages/musescore-api" },
		{ "path": "packages/core" },
		{ "path": "packages/checkers" }
	],
	"include": ["src/**/*", "scripts/**/*"]
}
