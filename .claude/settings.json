{
	"permissions": {
		"allow": [
			"Bash(pnpm *)",
			"Bash(turbo *)",
			"Bash(npx turbo *)",
			"Bash(node *)",
			"Bash(vitest *)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/block-protected-paths.sh"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/block-no-verify.sh"
					}
				]
			}
		]
	}
}
